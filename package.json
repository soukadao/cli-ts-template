{
  "name": "cli-ts-template",
  "version": "0.0.1",
  "description": "cli template",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "bun run type && esbuild src/cli.ts --minify --sourcemap --format=esm --target=node22 --outfile=dist/cli.js",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "type": "tsc --declaration --emitDeclarationOnly"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
